<Window
    x:Class="Aljaras.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:extensions="clr-namespace:Aljaras.Core"
    xmlns:local="clr-namespace:Aljaras"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:Aljaras.MVVM.ViewModel"
    Title="{Binding Global.AppLang.Apptitle}"
    Width="800"
    Height="450"
    AllowsTransparency="True"
    Background="Transparent"
    BorderBrush="{DynamicResource DarkBackgroundBrush}"
    BorderThickness="1"
    FlowDirection="{Binding Global.AppLang.FlowDirection}"
    ResizeMode="CanResizeWithGrip"
    WindowStyle="None"
    mc:Ignorable="d">
    <Window.DataContext>
        <viewModel:MainViewModel />
    </Window.DataContext>
    <Window.Resources>
        <DoubleAnimation
            x:Key="BeginAnimation"
            Storyboard.TargetProperty="Opacity"
            To="1"
            Duration="0:0:1" />
        <DoubleAnimation
            x:Key="StopAnimation"
            Storyboard.TargetProperty="Opacity"
            To="0"
            Duration="0:0:1" />
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <DockPanel
            Grid.ColumnSpan="2"
            Margin="0"
            Background="{DynamicResource DarkBackgroundBrush}">
            <!--#region  TitleBar-->
            <Border
                Height="40"
                Background="{DynamicResource DarkBackgroundBrush}"
                DockPanel.Dock="Top">
                <Border.InputBindings>
                    <MouseBinding Command="{Binding MoveWindowCommand}" MouseAction="LeftClick" />
                </Border.InputBindings>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="110" />
                    </Grid.ColumnDefinitions>
                    <StackPanel
                        Margin="15,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Path
                            Width="20"
                            Data="M1.230957,19.693036L30.768982,19.693036C31.506958,19.693036,32,20.185041,32,20.923019L32,22.154038C32,22.893054,31.506958,23.384999,30.768982,23.384999L1.230957,23.384999C0.49194336,23.384999,0,22.893054,0,22.154038L0,20.923019C0,20.185041,0.49194336,19.693036,1.230957,19.693036z M1.230957,9.8470059L30.768982,9.8470059C31.506958,9.8470059,32,10.339011,32,11.076989L32,12.30801C32,13.045987,31.506958,13.53903,30.768982,13.53903L1.230957,13.53903C0.49194336,13.53903,0,13.047025,0,12.30801L0,11.076989C0,10.339011,0.49194336,9.8470059,1.230957,9.8470059z M1.230957,0L30.768982,0C31.506958,-6.3337211E-08,32,0.49298194,32,1.2309594L32,2.4619804C32,3.1999579,31.506958,3.6930011,30.768982,3.6930013L1.230957,3.6930013C0.49194336,3.6930011,0,3.1999579,0,2.4619804L0,1.2309594C0,0.49298194,0.49194336,-6.3337211E-08,1.230957,0z"
                            Fill="LightGray"
                            Stretch="Uniform" />
                        <TextBlock
                            Margin="10,0,0,0"
                            FontFamily="Consolas"
                            FontSize="16"
                            Foreground="LightGray"
                            Text="{Binding Global.AppLang.Menu}" />
                    </StackPanel>
                    <TextBlock
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Consolas"
                        Foreground="LightGray">
                        <Run Text="{Binding Global.AppLang.Apptitle}" />
                        <Run Text="{Binding GetVersion}" />
                    </TextBlock>
                    <StackPanel
                        Grid.Column="2"
                        Margin="0,0,4,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <Button
                            extensions:Extensions.Carrier="M0,0L32,0 32,5.3 0,5.3z"
                            Command="{Binding MinimizeWindowCommand}"
                            Style="{DynamicResource TitleBarButton}" />
