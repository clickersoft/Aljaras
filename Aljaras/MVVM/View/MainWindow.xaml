<Window
    x:Class="Aljaras.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:extensions="clr-namespace:Aljaras.Core"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:Aljaras.MVVM.ViewModel"
    Title="{Binding Global.AppLang.Apptitle}"
    Width="800"
    Height="450"
    AllowsTransparency="True"
    Background="{DynamicResource DarkBackgroundBrush}"
    BorderBrush="{DynamicResource DarkBackgroundBrush}"
    BorderThickness="1"
    FlowDirection="{Binding Global.AppLang.FlowDirection}"
    ResizeMode="CanResizeWithGrip"
    WindowStyle="None"
    mc:Ignorable="d">
    <Window.DataContext>
        <viewModel:MainViewModel />
    </Window.DataContext>
    <Grid>
        <Grid.Style>
            <Style TargetType="{x:Type Grid}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                        <Setter Property="Margin" Value="0,0,0,8" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Normal">
                        <Setter Property="Margin" Value="0" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <DockPanel Grid.ColumnSpan="2" Background="{DynamicResource DarkBackgroundBrush}">
            <Border
                Height="40"
                Background="{DynamicResource DarkBackgroundBrush}"
                DockPanel.Dock="Top">
                <Border.InputBindings>
                    <MouseBinding Command="{Binding MoveWindowCommand}" MouseAction="LeftClick" />
                </Border.InputBindings>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel
                        Margin="15,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Path
                            Width="20"
                            Data="{StaticResource MenuPathData}"
                            Fill="{StaticResource LightGrayBrush}"
                            Stretch="Uniform" />
                        <TextBlock
                            Margin="10,0,0,0"
                            FontSize="16"
                            Foreground="{StaticResource LightGrayBrush}"
                            Text="{Binding Global.AppLang.Menu}" />
                    </StackPanel>
                    <TextBlock
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource WhiteBrush}">
                        <Run Text="{Binding Global.AppLang.Apptitle}" />
                        <Run Text="{Binding GetVersion}" />
                    </TextBlock>
                    <StackPanel
                        Grid.Column="2"
                        Margin="0,0,4,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <Button
                            extensions:Extensions.Carrier="{StaticResource MinimizePathData}"
                            Command="{Binding MinimizeWindowCommand}"
                            Style="{DynamicResource TitleBarButton}" />
                        <Button
                            extensions:Extensions.Carrier="{StaticResource MaximizePathData}"
                            Command="{Binding MaximizeWindowCommand}"
                            Style="{DynamicResource TitleBarButton}" />
                        <Button
                            extensions:Extensions.Carrier="{StaticResource ClosePathData}"
                            Command="{Binding ShutdownWindowCommand}"
                            Style="{DynamicResource TitleBarButton}" />
                    </StackPanel>
                </Grid>
            </Border>
            <Border
                Height="20"
                Background="{DynamicResource DarkBackgroundBrush}"
                DockPanel.Dock="Bottom">
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource WhiteBrush}">
                        <Path
                            Width="12"
                            Margin="0,0,0,-2"
                            Data="{StaticResource SystemTimePathData}"
                            Fill="{StaticResource WhiteBrush}"
                            Stretch="Uniform" />
                        <Run Text="{Binding Global.AppLang.SystemTime}" />
                        <Run FlowDirection="LeftToRight" Text="{Binding Global.SystemTime}" />
                    </TextBlock>
                    <Border
                        Margin="3"
                        BorderBrush="{StaticResource LightGrayBrush}"
                        BorderThickness="1,0,0,0" />
                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource WhiteBrush}">
                        <Path
                            Grid.Row="1"
                            Width="12"
                            Margin="0,0,0,-2"
                            Data="{StaticResource AlarmBellPathData}"
                            Fill="{StaticResource WhiteBrush}"
                            Stretch="Uniform" />
                        <Run Text="{Binding Global.AppLang.NextAlarm}" />
                        <Run FlowDirection="LeftToRight" Text="{Binding Global.CurrentAlarm}" />
                    </TextBlock>
                    <Border
                        Margin="3"
                        BorderBrush="{StaticResource LightGrayBrush}"
                        BorderThickness="1,0,0,0" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{StaticResource WhiteBrush}">
                        <Path
                            Grid.Row="2"
                            Height="12"
                            Margin="0,0,0,-2"
                            Data="{StaticResource TimeLeftPathData}"
                            Fill="{StaticResource WhiteBrush}"
                            Stretch="Uniform" />
                        <Run Text="{Binding Global.AppLang.TimeLeft}" />
                        <Run Text="{Binding Global.ShowTimeLeft}" />
                    </TextBlock>
                    <Border
                        Margin="3"
                        BorderBrush="{StaticResource LightGrayBrush}"
                        BorderThickness="1,0,0,0" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{StaticResource WhiteBrush}"
                        Visibility="Collapsed">
                        <Run Text="© Company, All rights reserved." />
                    </TextBlock>
                    <Button
                        Margin="3,0"
                        Command="{Binding ShowAboutMeViewCommand}"
                        Style="{StaticResource CopyrightButton}"
                        Visibility="Visible">
                        <TextBlock Margin="3,0">
                            <Run Text="© Free, Open Source." />
                        </TextBlock>
                    </Button>
                </StackPanel>
            </Border>
            <Border
                Width="48"
                HorizontalAlignment="Left"
                Background="{DynamicResource DarkBackgroundBrush}">
                <Border.Style>
                    <Style>
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Border.MouseEnter">
                                <EventTrigger.Actions>
                                    <BeginStoryboard Name="MyBeginStoryboard">
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(Border.Width)"
                                                To="150"
                                                Duration="0:0:.1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger.Actions>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Border.MouseLeave">
                                <EventTrigger.Actions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(Border.Width)"
                                                To="48"
                                                Duration="0:0:.1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger.Actions>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <RadioButton
                        extensions:Extensions.Carrier="{StaticResource EyePathData}"
                        Command="{Binding ShowMonitoringViewCommand}"
                        Content="{Binding Global.AppLang.Monitoring}"
                        IsChecked="True" />
                    <RadioButton
                        extensions:Extensions.Carrier="{StaticResource AlarmPathData}"
                        Command="{Binding ShowAlarmViewCommand}"
                        Content="{Binding Global.AppLang.Alarm}" />
                    <RadioButton
                        extensions:Extensions.Carrier="{StaticResource HolidayPathData}"
                        Command="{Binding ShowHolidaysViewCommand}"
                        Content="{Binding Global.AppLang.Holidays}" />
                    <RadioButton
                        extensions:Extensions.Carrier="{StaticResource SettingsPathData}"
                        Command="{Binding ShowSettingsViewCommand}"
                        Content="{Binding Global.AppLang.Settings}" />
                    <RadioButton
                        extensions:Extensions.Carrier="{StaticResource HelpPathData}"
                        Command="{Binding ShowAboutViewCommand}"
                        Content="{Binding Global.AppLang.Guide}" />
                </StackPanel>
            </Border>
            <ContentPresenter Content="{Binding CurrentView}" />
        </DockPanel>
        <ListBox
            x:Name="NotificationListBox"
            Grid.Row="2"
            Grid.Column="1"
            MaxWidth="200"
            Margin="0,40,0,30"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            d:ItemsSource="{d:SampleData ItemCount=5}"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding Global.NotificationList, Mode=TwoWay}"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            VirtualizingPanel.IsVirtualizing="False">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="LayoutTransform">
                        <Setter.Value>
                            <TranslateTransform />
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <EventTrigger.Actions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Opacity"
                                            From="0"
                                            To="1"
                                            Duration="0:0:0.5" />
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="LayoutTransform.X"
                                            From="0"
                                            To="200"
                                            Duration="0:0:3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger.Actions>
                        </EventTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border
                        Margin="0,0,0,5"
                        VerticalAlignment="Center"
                        Background="{Binding BackgroundColor}"
                        BorderBrush="{Binding BackgroundColor}"
                        BorderThickness="1"
                        CornerRadius="20,0,0,20">
                        <Grid Width="{Binding ActualWidth, ElementName=NotificationListBox}" Height="40">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Path
                                Height="25"
                                Margin="8,0"
                                Data="{StaticResource HelpPathData}"
                                Fill="{StaticResource WhiteBrush}"
                                Stretch="Uniform" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="{StaticResource WhiteBrush}"
                                Text="{Binding MessageText}"
                                TextWrapping="Wrap" />
                            <Border Grid.Column="2" Background="{StaticResource WhiteSmokeBrush}">
                                <Button
                                    Margin="2,0,6,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    extensions:Extensions.Carrier="{StaticResource CleanPathData}"
                                    Background="{Binding BackgroundColor}"
                                    Command="{Binding ElementName=NotificationListBox, Path=DataContext.Global.DeleteNotificationCommand}"
                                    CommandParameter="{Binding}"
                                    Style="{DynamicResource ListRoundButtons}" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
