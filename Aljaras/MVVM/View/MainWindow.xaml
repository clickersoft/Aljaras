                            Command="{Binding MaximizeWindowCommand}"
                            Style="{DynamicResource TitleBarButton}" />
                        <Button
                            extensions:Extensions.Carrier="M29.590818,0C30.206963,0 30.823227,0.23449993 31.292229,0.70349979 32.229256,1.6405001 32.229256,3.1605005 31.292229,4.1004992L19.398003,15.998498 31.292229,27.892495C32.229256,28.829499 32.229256,30.349496 31.292229,31.294496 30.354227,32.2315 28.827164,32.2315 27.890139,31.294496L15.997988,19.399499 4.1047992,31.296502C3.1677734,32.234498 1.6397347,32.234498 0.70276969,31.296502 -0.23425656,30.352502 -0.23425656,28.832498 0.70276969,27.894502L12.596934,15.998498 0.70276969,4.1024981C-0.23425656,3.1654978 -0.23425656,1.6454973 0.70276969,0.7054987 1.6397347,-0.23150158 3.1677734,-0.23150158 4.1047992,0.7054987L15.99695,12.597497 27.890139,0.70349979C28.35865,0.23449993,28.974674,0,29.590818,0z"
                            Command="{Binding ShutdownWindowCommand}"
                            Style="{DynamicResource TitleBarButton}" />
                    </StackPanel>

                </Grid>
            </Border>
            <!--#endregion  TitleBar-->

            <!--#region MonitoringBar-->
            <Border
                x:Name="g"
                Height="20"
                Background="{DynamicResource DarkBackgroundBrush}"
                DockPanel.Dock="Bottom">
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Foreground="White">
                        <Path
                            Width="15"
                            Margin="0,0,0,-2"
                            Data="{StaticResource SystemTimePathData}"
                            Fill="White"
                            Stretch="Uniform" />
                        <Run Text="{Binding Global.AppLang.SystemTime}" />
                        <Run FlowDirection="LeftToRight" Text="{Binding Global.SystemTime}" />
                    </TextBlock>
                    <Border
                        Margin="5,3"
                        BorderBrush="LightGray"
                        BorderThickness="1,0,0,0" />
                    <TextBlock VerticalAlignment="Center" Foreground="White">
                        <Path
                            Grid.Row="1"
                            Width="15"
                            Margin="0,0,0,-2"
                            Data="{StaticResource AlarmBellPathData}"
                            Fill="White"
                            Stretch="Uniform" />
                        <Run Text="{Binding Global.AppLang.NextAlarm}" />
                        <Run FlowDirection="LeftToRight" Text="{Binding Global.CurrentAlarm}" />
                    </TextBlock>
                    <Border
                        Margin="5,3"
                        BorderBrush="LightGray"
                        BorderThickness="1,0,0,0" />
                    <TextBlock VerticalAlignment="Center" Foreground="White">
                        <Path
                            Grid.Row="2"
                            Height="15"
                            Margin="0,0,0,-2"
                            Data="{StaticResource TimeLeftPathData}"
                            Fill="White"
                            Stretch="Uniform" />
                        <Run Text="{Binding Global.AppLang.TimeLeft}" />
                        <Run Text="{Binding Global.ShowTimeLeft}" />
                    </TextBlock>
                    <Border
                        Margin="5,3"
                        BorderBrush="LightGray"
                        BorderThickness="1,0,0,0" />
                    <Button
                        Margin="5,0"
                        Command="{Binding ShowAboutMeViewCommand}"
                        Style="{StaticResource CopyrightButton}">
                        <TextBlock Margin="5,0">
                            <Run Text="© Mustafa AlKlieb, All rights reserved." />
                        </TextBlock>
                    </Button>
                </StackPanel>
            </Border>
            <!--#endregion *** MonitoringBar ***-->

            <!--#region *** Main Menu ***-->
            <Border
                Width="48"
                HorizontalAlignment="Left"
                Background="{DynamicResource DarkBackgroundBrush}">
                <Border.Style>
                    <Style>
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Border.MouseEnter">
                                <EventTrigger.Actions>
                                    <BeginStoryboard Name="MyBeginStoryboard">
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(Border.Width)"
                                                To="145"
                                                Duration="0:0:.1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger.Actions>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Border.MouseLeave">
                                <EventTrigger.Actions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(Border.Width)"
                                                To="48"
                                                Duration="0:0:.1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger.Actions>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <RadioButton
                        extensions:Extensions.Carrier="{StaticResource EyePathData}"
                        Command="{Binding ShowMonitoringViewCommand}"
                        Content="{Binding Global.AppLang.Monitoring}"
                        IsChecked="True" />
                    <RadioButton
                        extensions:Extensions.Carrier="{StaticResource AlarmPathData}"
                        Command="{Binding ShowAlarmViewCommand}"
                        Content="{Binding Global.AppLang.Alarm}" />
                    <RadioButton
                        extensions:Extensions.Carrier="{StaticResource HolidayPathData}"
                        Command="{Binding ShowHolidaysViewCommand}"
                        Content="{Binding Global.AppLang.Holidays}" />
                    <RadioButton
                        extensions:Extensions.Carrier="{StaticResource SettingsPathData}"
                        Command="{Binding ShowSettingsViewCommand}"
                        Content="{Binding Global.AppLang.Settings}" />
                    <RadioButton
                        extensions:Extensions.Carrier="{StaticResource HelpPathData}"
                        Command="{Binding ShowAboutViewCommand}"
                        Content="{Binding Global.AppLang.Help}" />
                </StackPanel>
            </Border>
            <!--#endregion *** Main Menu ***-->

            <!--#region *** Render Views ***-->
            <ContentPresenter Content="{Binding CurrentView}" />
            <!--#endregion *** Render Views ***-->

        </DockPanel>

        <ListBox
            x:Name="NotificationListBox"
            Grid.Row="2"
            Grid.Column="1"
            MaxWidth="200"
            Margin="0,40,0,30"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            d:ItemsSource="{d:SampleData ItemCount=5}"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding Global.NotificationList, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            SelectionMode="Single"
            VirtualizingPanel.IsVirtualizing="False">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="IsSelected" Value="{Binding Content.IsSelected, Mode=TwoWay, RelativeSource={RelativeSource Self}}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <!--
                        Visibility="{Binding ActiveMessage, UpdateSourceTrigger=PropertyChanged}">
                    -->
                    <Border
                        Margin="0,0,0,5"
                        VerticalAlignment="Center"
                        Background="{Binding BackgroundColor}"
                        BorderBrush="{Binding BackgroundColor}"
                        BorderThickness="1"
                        CornerRadius="20,0,0,20">
                        <Grid Width="{Binding ActualWidth, ElementName=NotificationListBox}" Height="40">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Path
                                Height="25"
                                Margin="8,0"
                                Data="M16.800049,11.699997C16.100037,11.699997 15.300049,12 14.300049,12.5 13.400024,13 12.400024,13.900002 11.300049,15.099998L10.900024,15.5 12.400024,16.699997 12.700012,16.400002C13.900024,15.300003 14.300049,15 14.400024,14.900002 12.900024,20.199997 12.100037,23.400002 12.100037,24.800003 12.100037,25.300003 12.300049,25.800003 12.600037,26.099998 12.900024,26.400002 13.400024,26.599998 13.900024,26.599998 14.400024,26.599998 15,26.400002 15.800049,26 16.5,25.599998 17.600037,24.699997 19,23.300003L19.400024,22.900002 18,21.5 17.600037,21.800003C16.300049,23 15.700012,23.400002 15.600037,23.599998 15.600037,23 15.900024,21.5 17.200012,17.099998 18.200012,13.599998 18.200012,13.300003 18.200012,13.099998 18.200012,12.699997 18,12.300003 17.700012,12.099998 17.600037,11.800003 17.200012,11.699997 16.800049,11.699997z M16.700012,5.5999985C15.5,5.5999985 14.5,6.5999985 14.5,7.8000031 14.5,9 15.5,10 16.700012,10 17.900024,10 18.900024,9 18.900024,7.8000031 18.900024,6.5 17.900024,5.5999985 16.700012,5.5999985z M16,0C24.800049,0 32,7.1999969 32,16 32,24.800003 24.800049,32 16,32 7.2000122,32 0,24.800003 0,16 0,7.1999969 7.2000122,0 16,0z"
                                Fill="White"
                                Stretch="Uniform" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="White"
                                Text="{Binding MessageText}"
                                TextWrapping="Wrap" />
                            <Border Grid.Column="2" Background="WhiteSmoke">
                                <Button
                                    Margin="2,0,6,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    extensions:Extensions.Carrier="M20.008871,10.900169L12.408899,19.200307C12.408899,19.200307,17.708841,27.200435,18.408848,28.900458L20.508867,27.700442C20.508867,27.700442 19.00888,24.800395 18.108864,24.000386 18.108864,24.000386 17.308881,22.900363 18.708833,23.30037 18.708833,23.30037 21.908819,26.000419 22.408813,26.200419L24.508833,24.300387C24.508833,24.300387,24.208786,23.600379,23.808826,23.100369L21.308847,20.300323C21.308847,20.300323 20.808851,19.400306 21.908819,19.700314 21.908819,19.700314 24.608808,21.900346 26.308805,22.400355L28.008802,20.100322C28.008802,20.100322 24.908792,17.100274 24.708782,16.600266 24.708782,16.600266 24.208786,16.100257 24.908792,16.000258 24.908792,16.000258 28.108778,18.20029 29.30878,18.100289 29.30878,18.100289 30.308771,16.200257 30.208734,16.100257 30.108761,15.900249 21.508857,11.900186 20.008871,10.900169z M19.708824,8.5001373C22.608824,11.100177 30.508781,14.100225 30.508781,14.100225 32.708715,14.600233 31.808758,16.400258 31.808758,16.400258 28.008802,25.400403 19.00888,30.400483 19.00888,30.400483 17.408857,31.500506 16.608875,29.100467 16.608875,29.100467 14.808903,25.400403 10.108931,19.100306 10.108931,19.100306z M1.8090139,0C2.0090243,5.2599489E-08,2.1089992,5.2599489E-08,2.2089738,0.10000036L10.908911,8.0001287C11.008948,8.1001291,11.008948,8.2001285,11.108923,8.3001289L13.008931,6.300097C14.608892,5.4000806,16.008905,6.2000966,16.008905,6.2000966L18.308874,7.8001208 9.0089643,17.800282 7.4089419,15.600249C6.4089501,13.600218,7.6089522,12.200193,7.6089522,12.200193L9.2089145,10.400162C9.1089399,10.400162,9.0089643,10.400162,8.9089286,10.300161L0.20899085,2.4000327C0.0090414112,2.2000324,-0.090994357,1.9000245,0.10901623,1.6000244L1.4089929,0.10000036C1.6090034,0.10000013,1.7089781,5.2599489E-08,1.8090139,0z"
                                    Background="{Binding BackgroundColor}"
                                    Command="{Binding ElementName=NotificationListBox, Path=DataContext.Global.DeleteNotificationCommand}"
                                    CommandParameter="{Binding}"
                                    Style="{DynamicResource ListRoundButtons}" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
