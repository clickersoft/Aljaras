                    </Viewbox>
                    <TextBlock HorizontalAlignment="Center" Foreground="{StaticResource OrangeRedBrush}">
                        <Run Text="Audacity" />
                    </TextBlock>
                </StackPanel>
            </ListBoxItem>
            <ListBoxItem>
                <StackPanel>
                    <Path
                        Height="25"
                        Data="{StaticResource XMLPathData}"
                        Fill="{StaticResource TomatoBrush}"
                        Stretch="Uniform" />
                    <TextBlock HorizontalAlignment="Center" Foreground="{StaticResource TomatoBrush}">
                        <Run Text="XML" />
                    </TextBlock>
                </StackPanel>
            </ListBoxItem>
            <ListBoxItem>
                <StackPanel>
                    <Viewbox Width="40" Stretch="Uniform">
                        <Canvas Width="64" Height="64">
                            <Ellipse
                                Canvas.Left="0"
                                Canvas.Top="0"
                                Width="64"
                                Height="64"
                                Fill="{StaticResource DarkVioletBrush}" />
