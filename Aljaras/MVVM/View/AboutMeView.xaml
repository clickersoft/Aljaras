<UserControl
    x:Class="Aljaras.MVVM.View.AboutMeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Background="{StaticResource WhiteBrush}"
    mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
            <RowDefinition Height="80" />
        </Grid.RowDefinitions>
        <Grid VerticalAlignment="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Border
                Grid.Column="1"
                Margin="10,0"
                BorderBrush="{StaticResource LightGrayBrush}"
                BorderThickness="0,0,0,1" />
            <Grid>
                <Ellipse
                    Width="25"
                    Height="25"
                    Stroke="{StaticResource LightGrayBrush}" />
                <Path
                    Width="15"
                    Data="{StaticResource GraduationPathData}"
                    Fill="{StaticResource LightGrayBrush}"
                    Stretch="Uniform" />
            </Grid>
            <TextBlock
                Grid.Column="1"
                Margin="10,0"
                VerticalAlignment="Bottom"
                FontSize="16"
                Foreground="{StaticResource DarkBackgroundBrush}"
                Text="About Me" />
            <StackPanel Orientation="Horizontal" />
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Image
                MinWidth="200"
                Margin="5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Cursor=""
                Source="/mustafa.jpg" />
            <RichTextBox
                Grid.Column="1"
                Margin="10"
                BorderThickness="0"
                IsReadOnly="True"
                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                ScrollViewer.VerticalScrollBarVisibility="Auto">
                <FlowDocument>
                    <Paragraph FontWeight="Bold">
                        Hello I'm Mustafa AlKlieb
                    </Paragraph>
                    <Paragraph TextAlignment="Justify">
                        I am a developer with some commercial experience. Ability to think through a problem coupled with the confidence to make ideas heard. A proven ability to maintain and enhance company software with the aim of improving operational functionality in line with business requirement.
                    </Paragraph>
                    <Paragraph>
                        <Bold>Experience</Bold>
                    </Paragraph>
                    <List MarkerOffset="10" MarkerStyle="Disc">
                        <ListItem>
                            <Paragraph>
                                <Run Text="Palestinian Ministry of Education - Teacher ~ 2019 +" />
                            </Paragraph>
                        </ListItem>
                        <ListItem>
                            <Paragraph>
                                <Run Text="Clickersoft Company - developer(.Net-C#, Swift, Web Tech's...etc )/Designer/Technician  ~ 2013 to 2018" />
                            </Paragraph>
                        </ListItem>
                        <ListItem>
                            <Paragraph>
                                <Run Text="Dandis Bookshop - Technician/VOIP(FreePBX) ~ 2016 to 2018" />
                            </Paragraph>
                        </ListItem>
                        <ListItem>
                            <Paragraph>
                                <Run Text="Palestine  Ahliya  University - Diploma Instructor ~ 2013" />
                            </Paragraph>
                        </ListItem>
                    </List>
                    <Paragraph>
                        <Bold>Contact</Bold>
                    </Paragraph>
                    <List MarkerOffset="10" MarkerStyle="Disc">
                        <ListItem>
                            <Paragraph>
                                <Path
                                    Width="20"
                                    Data="{StaticResource GmailPathData}"
                                    Fill="{StaticResource IndianRedBrush}"
                                    Stretch="Uniform" />
                                <Run Text="Gmail:" />
                                <Hyperlink>
                                    <Run Text="g.musmiwhb@gmail.com" />
                                </Hyperlink>
                            </Paragraph>
                        </ListItem>
                        <ListItem>
                            <Paragraph>
                                <Path
                                    Width="20"
                                    Data="{StaticResource FacebookPathData}"
                                    Fill="{StaticResource SteelBlueBrush}"
                                    Stretch="Uniform" />
                                <Run Text="Facebook:" />
                                <Hyperlink>
                                    <Run Text="https://www.facebook.com/mustafa.alklieb.9/" />
                                </Hyperlink>
                            </Paragraph>
                        </ListItem>
                        <ListItem>
                            <Paragraph>
                                <Path
                                    Width="20"
                                    Data="{StaticResource WhatsAppPathData}"
                                    Fill="{StaticResource ForestGreenBrush}"
                                    Stretch="Uniform" />
                                <Run Text="WhatsApp:" />
                                <Hyperlink>
                                    <Run Text="+972597454045" />
                                </Hyperlink>
                            </Paragraph>
                        </ListItem>
                    </List>
                    <Paragraph>
                        <Bold Foreground="{StaticResource IndianRedBrush}">Notice:</Bold>
                        Audio library from Abu Yousef Software &quot;aljaras 2010&quot;<Hyperlink>
                            <Run Text="https://aljaras2010.blogspot.com/" />
                        </Hyperlink>
                    </Paragraph>
                    <Paragraph FlowDirection="RightToLeft" TextAlignment="Justify">
                        أقدم إليكم برنامج الجرس المدرسي لتنظيم الحصص المدرسية وفقاً لبرنامج الفصل الدراسي الخاص بالمدرسة ويركز البرنامج على السهولة والمرونة في الاستخدام ومُقدم بدون أي رسوم مالية فقط أطلب منكم الدعاء لي ولوالدي بالمغفرة والرحمة وجزاكم الله خيراً.
                        ملاحظة: تم الحصول على اصوات التنبيهات العربية من مطور البرمجيات سيد درويش - موقع المطور (aljaras2010.blogspot.com) - كإضافة للبرنامج فاذا امتلكت مكتبة اصوات اخرى تستطيع استخدامها بسهولة.
                        بيئة العمل:  Windows 7+, .net 7
                    </Paragraph>
                </FlowDocument>
            </RichTextBox>
            <Border
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="10,0"
                BorderBrush="{StaticResource LightGrayBrush}"
                BorderThickness="0,0,0,1" />
        </Grid>
        <ListBox
            Name="listBox2"
            Grid.Row="2"
            Background="Transparent"
            BorderThickness="0">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="30,0" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBoxItem>
                <StackPanel>
                    <Path
                        Width="25"
                        Height="25"
                        Data="{StaticResource VisualStudioPathData}"
                        Fill="{StaticResource DarkVioletBrush}"
                        Stretch="Uniform" />
                    <TextBlock HorizontalAlignment="Center" Foreground="{StaticResource DarkVioletBrush}">
                        <Run Text="Visual Studio" />
                    </TextBlock>
                </StackPanel>
            </ListBoxItem>
            <ListBoxItem>
                <StackPanel>
                    <Path
                        Width="25"
                        Height="25"
                        Data="{StaticResource CSharpPathData}"
                        Fill="{StaticResource OrangeRedBrush}"
                        Stretch="Uniform" />
                    <TextBlock HorizontalAlignment="Center" Foreground="{StaticResource OrangeRedBrush}">
                        <Run Text="CSharp" />
                    </TextBlock>
                </StackPanel>
            </ListBoxItem>
            <ListBoxItem>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Path
                            Width="25"
                            Height="25"
                            Data="{StaticResource LiteDBPathData}"
                            Fill="{StaticResource MediumGrayBrush}"
                            Stretch="Uniform" />
