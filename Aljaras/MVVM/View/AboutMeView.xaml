            Grid.Row="1"
            Margin="20,0,0,-5"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Background="{StaticResource WhiteBrush}"
            Foreground="{StaticResource IndianRedBrush}"
            Text="Technologies used in this app" />
    </Grid>
</UserControl>
