                            Margin="-6,0,0,-4"
                            VerticalAlignment="Bottom"
                            Foreground="{StaticResource MediumGrayBrush}">
                            <Run FontSize="20" Text="Lite" />
                            <Run
                                FontSize="20"
                                FontWeight="Bold"
                                Text="DB" />
                        </TextBlock>
                    </StackPanel>
                    <TextBlock HorizontalAlignment="Center" Foreground="{StaticResource MediumGrayBrush}">
                        <Run Text="LiteDB" />
                    </TextBlock>
                </StackPanel>
            </ListBoxItem>
            <ListBoxItem>
                <StackPanel>
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="20"
                        FontWeight="Bold">
                        <Run Foreground="{StaticResource DodgerBlueBrush}" Text="XAML" />
                    </TextBlock>
                    <TextBlock HorizontalAlignment="Center" Foreground="{StaticResource DodgerBlueBrush}">
                        <Run Text="WPF-XAML" />
                    </TextBlock>
