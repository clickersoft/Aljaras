<UserControl
    x:Class="Aljaras.MVVM.View.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:extensions="clr-namespace:Aljaras.Core"
    xmlns:local="clr-namespace:Aljaras.MVVM.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:Aljaras.MVVM.ViewModel"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Background="White"
    mc:Ignorable="d">
    <UserControl.DataContext>
        <viewmodel:SettingsViewModel />
    </UserControl.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Border
            Background="OldLace"
            BorderBrush="LightGray"
            BorderThickness="0,0,1,1">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Path
                    Width="60"
                    Data="{StaticResource LanguagePathData}"
                    Fill="Black"
                    Stretch="Uniform" />
                <TextBlock
                    Height="20"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Center"
                    FontSize="16"
                    Foreground="Black"
                    Text="{Binding Global.AppLang.Language}" />
                <ComboBox
                    Width="150"
                    HorizontalAlignment="Stretch"
                    FontSize="14"
                    ItemsSource="{Binding Lang}"
                    SelectedItem="{Binding UserSet.CurrentLang}" />
            </StackPanel>
        </Border>
        <Border
            Grid.Column="1"
            Background="LightYellow"
            BorderBrush="LightGray"
            BorderThickness="0,0,0,1">
            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <Path
                    Width="50"
                    Data="{StaticResource EmergencyPathData}"
                    Fill="Black"
                    Stretch="Uniform" />
                <TextBlock
                    Height="20"
                    HorizontalAlignment="Center"
                    FontSize="16"
                    Text="{Binding Global.AppLang.Emergency}" />
                <StackPanel
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        Margin="0,0,-20,0"
                        HorizontalAlignment="Center"
                        Panel.ZIndex="10"
                        extensions:Extensions.Icon="{StaticResource AudiFilePathData}"
                        Background="Gray"
                        Command="{Binding SelectEmergencyAudioFileCommand}"
                        Style="{DynamicResource RoundButtons}" />
                    <TextBox
                        Width="200"
                        Height="30"
                        Padding="20,0,0,0"
                        VerticalContentAlignment="Center"
                        Background="White"
                        FontWeight="Bold"
                        IsManipulationEnabled="False"
                        Text="{Binding UserSet.EmergencyAudioFileLocation}"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto" />
                    <Button
                        Margin="-15,0,0,0"
                        HorizontalAlignment="Center"
                        extensions:Extensions.Icon="{StaticResource PlayPathData}"
                        Background="Gray"
                        Command="{Binding PlayEmergencyAudioFileCommand}"
                        Style="{DynamicResource RoundButtons}" />
                </StackPanel>

            </StackPanel>
        </Border>

        <Border
            Grid.Row="1"
            Background="MintCream"
            BorderBrush="LightGray"
            BorderThickness="0,0,1,0">
            <StackPanel Grid.Row="2" VerticalAlignment="Center">
                <Path
                    Width="50"
                    Data="{StaticResource RepeatPathData}"
                    Fill="Black"
                    Stretch="Uniform" />
                <TextBlock
                    Height="20"
                    Margin="0,10"
                    HorizontalAlignment="Center"
                    FontSize="14"
                    Text="{Binding Global.AppLang.RepeatEmergency}" />
                <CheckBox
                    Height="20"
                    HorizontalAlignment="Center"
                    Content="{Binding Global.AppLang.EnableRepeat}"
                    Foreground="Green"
                    IsChecked="{Binding UserSet.RepeatEmergency}"
                    Style="{DynamicResource SliderCheckBox}" />
            </StackPanel>
        </Border>
        <Border
            Grid.Row="1"
            Grid.Column="1"
            Background="GhostWhite">
            <StackPanel Grid.Row="2" VerticalAlignment="Center">
                <Path
                    Width="50"
                    Data="{StaticResource DataBase}"
                    Fill="Black"
                    Stretch="Uniform" />
                <TextBlock
                    Height="20"
                    Margin="0,10"
                    HorizontalAlignment="Center"
                    FontSize="14"
                    Text="{Binding Global.AppLang.DatabaseOperations}" />
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <Button
                        extensions:Extensions.Icon="{StaticResource ImportDataBase}"
                        Background="DodgerBlue"
                        Command="{Binding ImportDataBaseCommand}"
                        Content="{Binding Global.AppLang.Import}"
                        Foreground="DodgerBlue"
                        Style="{DynamicResource ListRoundButtons}" />
                    <Button
                        Grid.RowSpan="10"
                        Grid.ColumnSpan="10"
                        Margin="20,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        extensions:Extensions.Icon="{StaticResource ExportDataBase}"
                        Background="ForestGreen"
                        Command="{Binding ExportDataBaseCommand}"
                        Content="{Binding Global.AppLang.Export}"
                        Foreground="ForestGreen"
                        Style="{DynamicResource ListRoundButtons}" />
                    <Button
                        Grid.RowSpan="10"
                        Grid.ColumnSpan="10"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        extensions:Extensions.Icon="{StaticResource DeleteDataBase}"
                        Background="OrangeRed"
                        Command="{Binding DeleteDataBaseCommand}"
                        Content="{Binding Global.AppLang.Delete}"
                        Foreground="OrangeRed"
                        Style="{DynamicResource ListRoundButtons}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Ellipse
            Grid.RowSpan="10"
            Grid.ColumnSpan="10"
            Width="100"
            Height="100"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Fill="White"
            Stroke="LightGray"
            StrokeThickness="1" />
        <Button
            Grid.RowSpan="10"
            Grid.ColumnSpan="10"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            extensions:Extensions.Icon="{DynamicResource SavePathData}"
            Background="#FF597ED8"
            Command="{Binding SaveSettingsCommand}"
            Content="{Binding Global.AppLang.Save}"
            FontSize="14"
            Foreground="#FF597ED8"
            Style="{DynamicResource ListRoundButtons}" />
